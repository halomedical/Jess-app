# ===========================================
# Halo Patient Concierge - Environment Config
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Session ---
# REQUIRED: Generate a strong random secret (e.g. openssl rand -hex 32)
SESSION_SECRET=

# --- Google OAuth 2.0 ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Gemini AI ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Halo Cloud Functions (optional) ---
# Base URL for generate_note / get_templates. If unset, a default region URL is used.
# When Halo returns 502 or is unreachable, note preview falls back to Gemini (SOAP) if GEMINI_API_KEY is set.
# HALO_API_BASE_URL=https://your-service.run.app
# HALO_USER_ID=<API user UUID that owns templates (must match Python backend)>
# Example UUID used when unset in server config: fcb5cfec-e10e-4c3a-bd44-064a788a6243

# --- Deepgram (optional) ---
# Medical transcription. Falls back to Gemini if not set.
# Get your key at https://console.deepgram.com/
DEEPGRAM_API_KEY=
# Faster default: nova-2-medical. For latest medical model: DEEPGRAM_MODEL=nova-3-medical
# DEEPGRAM_MODEL=nova-2-medical

# --- URLs ---
# Frontend URL (used for CORS and OAuth redirect)
CLIENT_URL=http://localhost:5173
# Production URL (used for OAuth redirect in production)
# PRODUCTION_URL=https://your-domain.com

# --- Email: Outlook + clinical note "Email" button (optional) ---
# Clinical notes are sent TO the signed-in Google user; FROM address is ADMIN_EMAIL (default admin@halo.africa).
#
# Pick SMTP_HOST by account type (both use port 587, SMTP_SECURE=false):
#   • Personal Microsoft account (@outlook.com, @hotmail.com, @live.com):
#       SMTP_HOST=smtp-mail.outlook.com
#   • Work or school (Microsoft 365 / Exchange Online, custom domains like @yourpractice.com):
#       SMTP_HOST=smtp.office365.com
#
# SMTP_USER / SMTP_PASS = that mailbox’s login. With two-step verification on, use an app password.
# ADMIN_EMAIL=admin@halo.africa
# SMTP_USER=admin@halo.africa
# SMTP_PASS=app-password-or-secret
# When set, "Request new template" in Settings also uses SMTP to send to ADMIN_EMAIL.
# Optional From for template requests only if different from SMTP_USER:
# SMTP_FROM=
#
# If you see SMTP error 535 "Authentication unsuccessful": the password is wrong for SMTP_USER,
# or Microsoft has blocked basic auth for that mailbox. Enable "Authenticated SMTP" (SMTP AUTH)
# for the mailbox in Microsoft 365 admin; with MFA use an app password in SMTP_PASS.
# ADMIN_EMAIL and SMTP_USER should match unless you have explicit Send As rights.
